tion>\n        <option>LWCBAC</option>\n        <option>LWFAC</option>\n        <option>LWLRRM</option>\n        <option>LWSCN</option>\n        <option>LWSCZ</option>\n        <option>LWSCZAC</option>\n        <option>LWSDD</option>\n        <option>MEMU/DMC</option>\n        <option>MEMU/MTC</option>\n        <option>SLR </option>\n        <option>TEJAS</option>\n        <option>TRC/TRSC</option>\n      </select>\n    </div>\n    <div>\n      <label style=\"display: block; font-weight: bold; color: #555; margin-bottom: 4px; font-size: 13px;\">FROM MONTH YEAR</label>\n      <select style=\"width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 3px; font-size: 12px;\">\n        <option>All Months From 04/2001</option>\n        <option>03/2026</option>\n        <option>02/2026</option>\n        <option>01/2026</option>\n        <option>12/2025</option>\n        <!-- full list abbreviated -->\n      </select>\n    </div>\n    <div>\n      <label style=\"display: block; font-weight: bold; color: #555; margin-bottom: 4px; font-size: 13px;\">TO MONTH YEAR</label>\n      <select style=\"width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 3px; font-size: 12px;\">\n        <option>All Months</option>\n        <option>03/2026</option>\n        <!-- full list -->\n      </select>\n    </div>\n  </form>\n  <div style=\"margin-top: 20px; text-align: center;\">\n    <button type=\"submit\" style=\"padding: 12px 30px; background: #007cba; color: white; border: none; border-radius: 4px; font-size: 14px; font-weight: bold;\">Submit</button>\n  </div>\n</div>",
