  "contentHtml": "<div id=\"heritage-slideshow\" style=\"position: relative; width: 100%; max-width: 800px; margin: 0 auto; overflow: hidden; border-radius: 8px;\"></div>\n<script>\n(function() {\n  var images = [\n    \"/heritage/her 3.jpg\",\n    \"/heritage/her4.jpg\", \n    \"/heritage/her 5.jpg\",\n    \"/heritage/her 6.jpg\",\n    \"/heritage/her 7.jpg\",\n    \"/heritage/image2.jpeg\",\n    \"/heritage/park.jpeg\"\n  ];\n  var container = document.getElementById('heritage-slideshow');\n  var current = 0;\n  function showSlide(index) {\n    container.innerHTML = '<img src=\"' + images[index] + '\" alt=\"Heritage\" style=\"width:100%;height:auto;display:block;\">';\n  }\n  showSlide(current);\n  setInterval(function() {\n    current = (current + 1) % images.length;\n    showSlide(current);\n  }, 3000);\n})();\n</script>\n\n<style>\n.heritage-section {\n  margin-top: 1.5rem;\n}\n.heritage-title {\n  font-size: 1.1rem;\n  font-weight: 600;\n  color: #1e3a5f;\n  margin-bottom: 0.75rem;\n  padding-bottom: 0.35rem;\n  border-bottom: 2px solid #0066cc;\n  display: inline-block;\n}\n.heritage-card {\n  display: flex;\n  align-items: center;\n  padding: 0.75rem;\n  background: linear-gradient(135deg, #ffffff 0%, #f0f7ff 100%);\n  border-radius: 8px;\n  border: 1px solid #d0e2f0;\n  text-decoration: none;\n  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n  margin-bottom: 0.5rem;\n  box-shadow: 0 1px 4px rgba(0, 102, 204, 0.06);\n}\n.heritage-card:hover {\n  background: linear-gradient(135deg, #e6f0ff 0%, #d0e2f0 100%);\n  border-color: #0066cc;\n  transform: translateY(-2px);\n  box-shadow: 0 4px 12px rgba(0, 102, 204, 0.15);\n}\n.heritage-icon {\n  width: 32px;\n  height: 32px;\n  background: linear-gradient(135deg, #0066cc 0%, #004499 100%);\n  border-radius: 6px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 1rem;\n  margin-right: 0.6rem;\n  flex-shrink: 0;\n}\n.heritage-card:hover .heritage-icon {\n  transform: scale(1.05);\n}\n.heritage-content {\n  flex: 1;\n}\n.heritage-card strong {\n  color: #1e3a5f;\n  display: block;\n  font-size: 0.85rem;\n  margin-bottom: 0.15rem;\n  transition: color 0.2s ease;\n}\n.heritage-card:hover strong {\n  color: #0066cc;\n}\n.heritage-desc {\n  color: #64748b;\n  font-size: 0.75rem;\n  margin: 0;\n}\n.heritage-arrow {\n  color: #94a3b8;\n  font-size: 0.9rem;\n  margin-left: 0.5rem;\n  transition: all 0.3s ease;\n}\n.heritage-card:hover .heritage-arrow {\n  color: #0066cc;\n  transform: translateX(3px);\n}\n</style>\n\n<div class=\"heritage-section\">\n  <h2 class=\"heritage-title\">Heritage Documents</h2>\n  <a href=\"https://mcf.indianrailways.gov.in/uploads/1751697950955G%20Branch.pdf\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"heritage-card\">\n    <div class=\"heritage-icon\">📜</div>\n    <div class=\"heritage-content\">\n      <strong>Glimpses of The Highway of Hindostan</strong>\n      <p class=\"heritage-desc\">Written by Sh. P. K. Mishra, General Manager, MCF</p>\n    </div>\n    <span class=\"heritage-arrow\">→</span>\n  </a>\n  <a href=\"https://mcf.indianrailways.gov.in/uploads/The%20Great%20Junction%20Jubblepore%20and%20the%20Long%20Arc%20of%20Connection%20(1865-67).pdf\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"heritage-card\">\n    <div class=\"heritage-icon\">🚂</div>\n    <div class=\"heritage-content\">\n      <strong>The Great Junction: Jubbulpore and the Long Arc of Connection (1865-67)</strong>\n    </div>\n    <span class=\"heritage-arrow\">→</span>\n  </a>\n  <a href=\"https://mcf.indianrailways.gov.in/uploads/Opening%20of%20the%20Line%20to%20Benares.pdf\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"heritage-card\">\n    <div class=\"heritage-icon\">🛤️</div>\n    <div class=\"heritage-content\">\n      <strong>Opening of the Line to Benares</strong>\n    </div>\n    <span class=\"heritage-arrow\">→</span>\n  </a>\n  <a href=\"https://mcf.indianrailways.gov.in/uploads/The%20Santhal%20Uprising%20and%20the%20Iron%20Road.pdf\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"heritage-card\">\n    <div class=\"heritage-icon\">🏛️</div>\n    <div class=\"heritage-content\">\n      <strong>The Santhal Uprising and the Iron Road</strong>\n    </div>\n    <span class=\"heritage-arrow\">→</span>\n  </a>\n</div>",
